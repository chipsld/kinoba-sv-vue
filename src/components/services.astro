---
import { SERVICES_ITEMS } from '../consts';

// Brand accent per service: yellow → red → blue → yellow
const ACCENTS = [
  { border: 'border-l-yellow-500', pill: 'bg-yellow-500/15 text-yellow-700' },
  { border: 'border-l-red-500',    pill: 'bg-red-500/15 text-red-600'      },
  { border: 'border-l-blue-500',   pill: 'bg-blue-500/15 text-blue-700'    },
  { border: 'border-l-yellow-500', pill: 'bg-yellow-500/15 text-yellow-700' },
];
---

<section class="section-gray" data-services-section>
  <div class="grid gap-4 grid-cols-1 md:grid-cols-2">
    {SERVICES_ITEMS.map((service, i) => {
      const accent = ACCENTS[i % ACCENTS.length]!;
      return (
        <article
          class={`rounded-xl border border-l-4 border-black/10 bg-background/70 p-6 md:p-8 ${accent.border}`}
          data-service-card
          style="opacity: 0; transform: translateY(18px);"
        >
          <span class={`inline-block px-2 py-0.5 rounded text-xs font-medium uppercase tracking-wide mb-3 ${accent.pill}`}>
            {service.icon}
          </span>
          <h3 class="h3 text-black mb-3">{service.title}</h3>
          <p class="text-black/80">{service.description}</p>
        </article>
      );
    })}
  </div>
</section>

<script>
  import { animate } from 'motion-v';

  const section = document.querySelector('[data-services-section]');
  const cards = section ? Array.from(section.querySelectorAll('[data-service-card]')) : [];

  if (section && cards.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        const [entry] = entries;

        if (!entry) return;

        if (entry.isIntersecting) {
          animate(
            cards,
            { opacity: [0, 1], y: [18, 0] },
            {
              duration: 3,
              delay: (index) => index * 0.08,
              ease: [0.22, 1, 0.36, 1],
            },
          );
          return;
        }

        cards.forEach((card) => {
          card.style.opacity = '0';
          card.style.transform = 'translateY(18px)';
        });
      },
      { threshold: 0.2 },
    );

    observer.observe(section);
  }
</script>

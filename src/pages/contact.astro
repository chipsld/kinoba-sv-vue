---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import Background from '@/components/background.vue';
import ContactForm from '@/components/contact-form.vue';
---

<DefaultLayout title="Contact | Kinoba" description="Une question ? Contacte-nous ! Que tu souhaites discuter de ton projet web ou rejoindre la tribu, nous sommes là.">
  <Background className="via-muted to-muted/80">

    <!-- Hero -->
    <section class="relative pt-40 pb-16 lg:pt-52 lg:pb-24">
      <div class="layout">
        <h1 class="h1 mb-6">Nous contacter</h1>
        <p class="text-xl text-muted-foreground max-w-2xl">Que tu souhaites nous solliciter pour discuter de ton projet web, rejoindre la tribu ou pour toute autre question — nous avons besoin de quelques informations.</p>
      </div>
    </section>

    <!-- Form + Info -->
    <section class="py-16 lg:py-24 bg-white">
      <div class="layout grid lg:grid-cols-2 gap-12 lg:gap-20">

        <!-- Form -->
        <div>
          <p class="text-gray-600 mb-8">Dès que tu auras rempli ce formulaire, un membre de l'équipe reviendra vers toi dans les plus brefs délais.</p>
          <ContactForm client:only="vue" />
        </div>

        <!-- Contact info -->
        <div class="flex flex-col gap-8 lg:pt-4">
          <div>
            <h2 class="h3 mb-4">On se trouve ici</h2>
            <div class="flex flex-col gap-4">
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 mt-0.5 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <div>
                  <p class="font-medium text-sm">Lyon</p>
                  <p class="text-gray-600 text-sm">7 place Ferrandière, 69003 Lyon</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 mt-0.5 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <div>
                  <p class="font-medium text-sm">Paris</p>
                  <p class="text-gray-600 text-sm">94 rue du Temple, 75003 Paris</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 mt-0.5 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <div>
                  <p class="font-medium text-sm">Email</p>
                  <a href="mailto:hello@kinoba.fr" class="text-gray-600 text-sm hover:text-black transition-colors">hello@kinoba.fr</a>
                </div>
              </div>
            </div>
          </div>

          <div>
            <h2 class="h3 mb-4">Nous suivre</h2>
            <div class="flex gap-4">
              {[
                { name: 'LinkedIn', href: 'https://www.linkedin.com/company/kinoba/', icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>` },
                { name: 'GitHub', href: 'https://github.com/kinoba', icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>` },
                { name: 'Medium', href: 'https://kinoba.medium.com', icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/></svg>` },
              ].map((s) => (
                <a
                  href={s.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center justify-center w-10 h-10 rounded-full border border-gray-200 text-gray-600 hover:border-black hover:text-black transition-colors"
                  aria-label={s.name}
                  set:html={s.icon}
                />
              ))}
            </div>
          </div>
        </div>

      </div>
    </section>

  </Background>
</DefaultLayout>
